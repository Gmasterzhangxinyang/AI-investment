# Python/cache
__pycache__/
*.py[cod]
*$py.class
*.tmp
.venv/
venv/
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local secrets and environment
.env
.env.*
!.env.example

# macOS/editor noise
.DS_Store
.idea/
.vscode/

# Node/build artifacts
node_modules/
**/node_modules
/dist/
/build/
templates/build/output/

# Runtime logs
logs/*
!logs/.gitkeep
*.log

# Generated reports and dashboards
outputs/*
!outputs/.gitkeep

# Local databases and backups
data/*.db
data/*.db-*
data/db_backups/
*.sqlite
*.sqlite3
*.db

# Source Excel snapshots and archives contain local/private data.
data/archive/
data/current/
data/wind/current/*
data/wind/current/*.xlsx
!data/wind/current/.gitkeep

# Temporary spreadsheet inspection artifacts.
*.inspect.ndjson

# Local delivery archives
*.zip
/runtime/
